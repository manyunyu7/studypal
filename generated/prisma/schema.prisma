generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              Role                @default(USER)
  accounts          Account[]
  sessions          Session[]
  quizAttempts      QuizAttempt[]
  flashcardProgress FlashcardProgress[]
  questionProgress  QuestionProgress[]
  bookmarks         QuestionBookmark[]
  themePreference   Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Semester {
  id        Int       @id @default(autoincrement())
  name      String
  year      String?
  subjects  Subject[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  icon        String?
  semesterId  Int
  semester    Semester @relation(fields: [semesterId], references: [id])
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Topic {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?       @db.Text
  order        Int           @default(0)
  subjectId    Int
  subject      Subject       @relation(fields: [subjectId], references: [id])
  questions    Question[]
  flashcards   Flashcard[]
  mindmapNodes MindmapNode[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Question {
  id          Int                @id @default(autoincrement())
  text        String             @db.Text
  explanation String?            @db.Text
  difficulty  Difficulty         @default(MEDIUM)
  tag         String?
  order       Int                @default(0)
  topicId     Int
  topic       Topic              @relation(fields: [topicId], references: [id])
  options     QuestionOption[]
  answers     QuizAnswer[]
  progress    QuestionProgress[]
  bookmarks   QuestionBookmark[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([topicId])
}

model QuestionOption {
  id         Int      @id @default(autoincrement())
  text       String   @db.Text
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        Int          @id @default(autoincrement())
  userId    String
  topicId   Int? // null for cross-topic "try out" attempts
  subjectId Int? // set for subject-level "try out" attempts
  score     Int
  total     Int
  user      User         @relation(fields: [userId], references: [id])
  answers   QuizAnswer[]
  createdAt DateTime     @default(now())

  @@index([topicId])
  @@index([subjectId])
}

model QuizAnswer {
  id               Int         @id @default(autoincrement())
  quizAttemptId    Int
  questionId       Int
  selectedOptionId Int?
  isCorrect        Boolean
  quizAttempt      QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question         Question    @relation(fields: [questionId], references: [id])
}

model Flashcard {
  id        Int                 @id @default(autoincrement())
  front     String              @db.Text
  back      String              @db.Text
  order     Int                 @default(0)
  topicId   Int
  topic     Topic               @relation(fields: [topicId], references: [id])
  progress  FlashcardProgress[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model FlashcardProgress {
  id           Int       @id @default(autoincrement())
  userId       String
  flashcardId  Int
  mastered     Boolean   @default(false)
  // ── Spaced-repetition (SM-2) state ──
  ease         Float     @default(2.5)
  interval     Int       @default(0) // days until next review
  repetitions  Int       @default(0)
  dueDate      DateTime?
  lastReviewed DateTime?
  user         User      @relation(fields: [userId], references: [id])
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id])
  updatedAt    DateTime  @updatedAt

  @@unique([userId, flashcardId])
}

model QuestionProgress {
  id           Int      @id @default(autoincrement())
  userId       String
  questionId   Int
  timesCorrect Int      @default(0)
  timesWrong   Int      @default(0)
  lastCorrect  Boolean?
  lastSeen     DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

model QuestionBookmark {
  id         Int      @id @default(autoincrement())
  userId     String
  questionId Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

model MindmapNode {
  id        Int           @id @default(autoincrement())
  label     String
  content   String?       @db.Text
  posX      Float         @default(0)
  posY      Float         @default(0)
  color     String?
  topicId   Int
  topic     Topic         @relation(fields: [topicId], references: [id])
  parentId  Int?
  parent    MindmapNode?  @relation("NodeChildren", fields: [parentId], references: [id])
  children  MindmapNode[] @relation("NodeChildren")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
